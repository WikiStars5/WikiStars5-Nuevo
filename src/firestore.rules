
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
      // --- App Check Enforcement ---
    match /{path=**} {
      allow read: if true;
      allow write: if request.app.token.app_id != null;
    }

    // --- Funciones de Utilidad Reutilizables ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function isAdmin() { return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); }
    
    // --- Reglas de Colecciones ---

    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isSignedIn(); // Allow anyone to update follower counts via transaction
      allow delete: if isOwner(userId) || isAdmin();

      match /followers/{followerId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == followerId;
      }
      match /following/{followedId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
      match /starposts/{postId} { 
        allow read: if true; 
        allow write, delete: if isOwner(userId); 
      }
      match /thoughts/{thoughtId} { 
        allow read: if true; 
        allow write, delete: if isOwner(userId); 
      }
      match /saved_thoughts/{thoughtId} { 
        allow read, write, delete: if isOwner(userId); 
      }
      match /attitudeVotes/{figureId} { allow get, write: if isOwner(userId); allow list: if isOwner(userId) || isAdmin(); }
      match /emotionVotes/{figureId} { allow get, write: if isOwner(userId); allow list: if isOwner(userId) || isAdmin(); }
      match /streaks/{streakId} { allow get, write: if isOwner(userId) || isAdmin(); allow list: if isOwner(userId) || isAdmin(); }
      match /notifications/{notificationId} { allow read, update, delete: if isOwner(userId); allow list: if isOwner(userId) || isAdmin(); allow create: if isSignedIn(); }
      match /referrals/{referredUserId} { allow read, write: if isOwner(userId); allow list: if isOwner(userId) || isAdmin(); }
      match /adCampaigns/{campaignId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /achievements/{figureId} { allow get, write: if isOwner(userId); allow list: if isOwner(userId) || isAdmin(); }
    }

    match /usernames/{username} {
      allow get: if true; 
      allow create: if isSignedIn(); 
      allow delete: if get(/databases/$(database)/documents/usernames/$(username)).data.userId == request.auth.uid;
    }

    match /figures/{figureId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() || isSignedIn();
      
      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if resource.data.userId == request.auth.uid || isAdmin();
        match /votes/{userId} { allow get, write: if isOwner(userId); }
        match /replies/{replyId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update: if isSignedIn();
          allow delete: if resource.data.userId == request.auth.uid || isAdmin();
          match /votes/{userId} { allow get, write: if isOwner(userId); }
        }
      }
      match /thoughts/{thoughtId} {
        allow get, list: if true;
        allow create: if request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if resource.data.userId == request.auth.uid || isAdmin();
        match /votes/{userId} { allow get, write: if isOwner(userId); }
        match /replies/{replyId} {
          allow get, list: if true;
          allow create: if isSignedIn();
          allow update: if isSignedIn();
          allow delete: if resource.data.userId == request.auth.uid || isAdmin();
          match /votes/{userId} { allow get, write: if isOwner(userId); }
        }
      }
      match /streaks/{userId} { allow read, list: if true; allow write: if isOwner(userId) || isAdmin(); }
    }
    
    match /stats/notifications {
      allow read: if true;
      allow update: if isSignedIn() || isAdmin();
      allow create: if isSignedIn() || isAdmin();
    }

    match /stats/{statId} { allow read: if true; allow write: if isAdmin(); }
    match /roles_admin/{userId} { allow get: if isOwner(userId) || isAdmin(); allow write, list: if isAdmin(); }
    match /settings/{settingId} { allow read: if true; allow write: if isAdmin(); }
    match /goat_battles/{battleId} {
        allow get, list: if true;
        allow create, delete, update: if isAdmin();
        match /votes/{userId} { allow get: if isOwner(userId) || isAdmin(); allow write: if isOwner(userId); }
    }
  }
}
