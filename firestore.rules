rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funciones de Utilidad Reutilizables ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isIncrement(field, count) {
      return (resource == null && request.resource.data[field] == count) || 
             (request.resource.data[field] == resource.data[field] + count);
    }

    function isDecrement(field, count) {
      return request.resource.data[field] == resource.data[field] - count;
    }
    
    function getGlobalSettings() {
      return get(/databases/$(database)/documents/settings/global).data;
    }

    function areCommentsEnabled() {
      return getGlobalSettings().isCommentingEnabled == true;
    }
    
    function areRepliesEnabled() {
      return getGlobalSettings().isReplyEnabled == true;
    }
    
    function areRatingsEnabled() {
      return getGlobalSettings().isRatingEnabled == true;
    }
    
    // --- Funciones de Validación de Votos ---
    
    function isVoteIncrement(voteType, voteField) {
      let prevVoteMap = resource.data[voteType] != null ? resource.data[voteType] : {};
      let nextVoteMap = request.resource.data[voteType];
      let prevCount = prevVoteMap[voteField] != null ? prevVoteMap[voteField] : 0;
      return nextVoteMap[voteField] == prevCount + 1 && nextVoteMap.diff(prevVoteMap).affectedKeys().hasOnly([voteField]);
    }

    function isVoteDecrement(voteType, voteField) {
      let prevVoteMap = resource.data[voteType] != null ? resource.data[voteType] : {};
      let nextVoteMap = request.resource.data[voteType];
      let prevCount = prevVoteMap[voteField];
      return prevCount != null && nextVoteMap[voteField] == prevCount - 1 && nextVoteMap.diff(prevVoteMap).affectedKeys().hasOnly([voteField]);
    }

    function isChangingVote(voteType, oldVoteField, newVoteField) {
      let prevVoteMap = resource.data[voteType] != null ? resource.data[voteType] : {};
      let nextVoteMap = request.resource.data[voteType];
      let prevOldCount = prevVoteMap[oldVoteField];
      let prevNewCount = prevVoteMap[newVoteField] != null ? prevVoteMap[newVoteField] : 0;
      return prevOldCount != null && nextVoteMap[oldVoteField] == prevOldCount - 1 && nextVoteMap[newVoteField] == prevNewCount + 1 && nextVoteMap.diff(prevVoteMap).affectedKeys().hasOnly([oldVoteField, newVoteField]);
    }
    
    // --- Reglas de Colecciones ---

    match /users/{userId} {
      // 1. Perfil de Usuario
      // Permitimos leer cualquier perfil a usuarios logueados (necesario para seguir y ver perfiles públicos)
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isSignedIn() && (
        isOwner(userId) || 
        isAdmin() ||
        // Permitir a otros usuarios (mediante transacciones) actualizar contadores y datos de visita
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount', 'followingCount', 'visitCount', 'lastVisit'])
      );
      allow delete: if isAdmin();

      // 2. Sub-colecciones de Usuario
      
      match /achievements/{figureId} {
        allow read: if true; 
        allow write: if isOwner(userId) || isAdmin();
      }

      match /attitudeVotes/{figureId} { allow get, write: if isOwner(userId); allow list: if isOwner(userId) || isAdmin(); }
      match /emotionVotes/{figureId} { allow get, write: if isOwner(userId); allow list: if isOwner(userId) || isAdmin(); }
      match /btsBiasVote/{battleId} { allow get, write: if isOwner(userId); allow list: if false; }
      match /blackpinkBiasVote/{battleId} { allow get, write: if isOwner(userId); allow list: if false; }
      
      match /streaks/{figureId} { 
        allow read: if true; 
        allow write: if isOwner(userId) || isAdmin(); 
      }
      
      match /notifications/{notificationId} { 
        allow read, update, delete: if isOwner(userId); 
        allow list: if isOwner(userId) || isAdmin(); 
        allow create: if isSignedIn(); 
      }
      
      match /referrals/{referredUserId} { allow read, write: if isOwner(userId); allow list: if isOwner(userId) || isAdmin(); }
      match /adCampaigns/{campaignId} { allow read, write: if isOwner(userId) || isAdmin(); }

      match /followers/{followerId} {
        allow read: if true; 
        // Permitir que el usuario logueado se añada/elimine de la lista de seguidores de otro
        allow write: if request.auth.uid == followerId; 
      }

      match /following/{followedId} {
        allow read: if true; 
        // Solo el dueño gestiona a quién sigue
        allow write: if isOwner(userId); 
      }
      
      // Referencias a contenido y guardados
      match /starposts/{postId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /thoughts/{thoughtId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /saved_starposts/{postId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /saved_thoughts/{thoughtId} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    match /usernames/{username} {
      allow get: if true; 
      allow create: if isSignedIn(); 
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/usernames/$(username)).data.userId == request.auth.uid;
    }

    match /figures/{figureId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      
      allow update: if isAdmin() || (
        isSignedIn() && (
          // Información básica
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'imageUrl', 'imageHint', 'coverPhotoUrl', 'nationality', 'description', 'gender', 'birthDate', 'deathDate', 'occupation', 'maritalStatus', 'height', 'socialLinks', 'nameKeywords', 'updatedAt'])) ||
          
          // Votos de actitud
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['attitude', 'updatedAt', '__oldVote', '__newVote']) && (
            (request.resource.data.__oldVote == null && isVoteIncrement('attitude', request.resource.data.__newVote)) ||
            (request.resource.data.__newVote == null && isVoteDecrement('attitude', request.resource.data.__oldVote)) || 
            (request.resource.data.__oldVote == request.resource.data.__newVote && isVoteDecrement('attitude', request.resource.data.__oldVote)) ||
            (request.resource.data.__oldVote != request.resource.data.__newVote && isChangingVote('attitude', request.resource.data.__oldVote, request.resource.data.__newVote))
          )) ||

          // Votos de emoción
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['emotion', 'updatedAt', '__oldVote', '__newVote']) && (
            (request.resource.data.__oldVote == null && isVoteIncrement('emotion', request.resource.data.__newVote)) ||
            (request.resource.data.__newVote == null && isVoteDecrement('emotion', request.resource.data.__oldVote)) ||
            (request.resource.data.__oldVote == request.resource.data.__newVote && isVoteDecrement('emotion', request.resource.data.__oldVote)) ||
            (request.resource.data.__oldVote != request.resource.data.__newVote && isChangingVote('emotion', request.resource.data.__oldVote, request.resource.data.__newVote))
          )) ||

          // Contadores de reseñas y rachas
          (request.resource.data.diff(resource.data).affectedKeys().hasAny(['ratingCount', 'totalRating', 'ratingsBreakdown', 'activeStreakCount', 'btsBiasVoteCount', 'blackpinkBiasVoteCount', 'shareCounts']))
        )
      );
      
      match /attitudeStats/{statId} { allow read, list: if true; allow write: if isSignedIn(); }
      match /emotionStats/{statId} { allow read, list: if true; allow write: if isSignedIn(); }
      match /ratingStats/{rating} { allow read, list: if true; allow write: if isSignedIn(); }
      match /streakStats/{day} { allow read, list: if true; allow write: if isSignedIn(); }
      
      match /comments/{commentId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

        match /votes/{userId} { allow get, write: if isOwner(userId); }
        match /replies/{replyId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow update: if isSignedIn();
          allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
          match /votes/{userId} { allow get, write: if isOwner(userId); }
        }
      }

      match /thoughts/{thoughtId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn();
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
        match /votes/{userId} { allow get, write: if isOwner(userId); }
        match /replies/{replyId} {
          allow get, list: if true;
          allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
          allow update: if isSignedIn();
          allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
          match /votes/{userId} { allow get, write: if isOwner(userId); }
        }
      }

      match /streaks/{userId} { allow read, list: if true; allow write: if isOwner(userId) || isAdmin(); }
      match /news/{newsId} { allow read: if true; allow write: if isAdmin(); }
      match /gallery/{photoId} { allow read: if true; allow write: if isAdmin(); }
    }
    
    match /achievements/{achievementId} { allow get, list: if true; allow write: if isAdmin(); }
    match /related_figures/{relatedFigureId} { allow get, list: if true; allow create, delete: if isSignedIn(); }
    match /goat_battles/{battleId} { allow get, list: if true; allow write: if isAdmin(); match /votes/{userId} { allow get, write: if isOwner(userId) || isAdmin(); } }
    match /roles_admin/{userId} { allow get: if isOwner(userId) || isAdmin(); allow write, list: if isAdmin(); }
    match /settings/{settingId} { allow read: if true; allow write: if isAdmin(); }
    match /stats/{statId} { allow read: if true; allow write: if isAdmin(); }
    match /user_stats/{statId} { allow read, write: if true; }
    match /featured_figures/{figureId} { allow read: if true; allow write, delete: if isAdmin(); }
    match /election_candidates_2026/{candidateId} { allow read: if true; allow write: if isAdmin(); }
    match /bts_bias_members/{figureId} { allow read: if true; allow write: if isAdmin(); }
    match /blackpink_bias_members/{figureId} { allow read: if true; allow write: if isAdmin(); }
  }
}