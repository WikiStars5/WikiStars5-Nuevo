
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the WikiStars5 platform, whether registered or anonymous.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "usernameLower": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePhotoUrl": { "type": "string" },
        "country": { "type": "string" },
        "gender": { "type": "string" },
        "description": { "type": "string", "maxLength": 160 },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "fcmTokens": { "type": "array", "items": { "type": "string" } },
        "tokenCount": { "type": "number" },
        "referralCount": { "type": "number" },
        "visitCount": { "type": "number" },
        "lastVisit": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    },
    "NotificationStats": {
      "title": "NotificationStats",
      "type": "object",
      "properties": {
        "totalSubscribers": { "type": "number" }
      }
    },
    "AdCampaign": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdCampaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "campaignName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "pending_review", "active", "paused", "rejected", "completed"] },
        "type": { "type": "string", "enum": ["cpc", "cpm"] },
        "budget": { "type": "number" },
        "spent": { "type": "number" },
        "results": { "type": "number" }
      },
      "required": ["id", "userId", "campaignName", "status", "type"]
    },
    "PublicFigure": {
      "title": "PublicFigure",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "activeStreakCount": { "type": "number" }
      }
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "Stores user profiles including push tokens." }
      },
      {
        "path": "/stats/notifications",
        "definition": { "entityName": "NotificationStats", "description": "Global counter for push subscribers." }
      }
    ]
  }
}
