
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the WikiStars5 platform, whether registered or anonymous.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "usernameLower": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePhotoUrl": { "type": "string" },
        "country": { "type": "string" },
        "gender": { "type": "string" },
        "description": { "type": "string", "maxLength": 160 },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "referralCount": { "type": "number" },
        "followerCount": { "type": "number", "description": "Number of users following this user." },
        "followingCount": { "type": "number", "description": "Number of users this user follows." },
        "visitCount": { "type": "number" },
        "lastVisit": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    },
    "Follower": {
      "title": "Follower",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "profilePhotoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Following": {
      "title": "Following",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "profilePhotoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AdCampaign": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdCampaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "campaignName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "pending_review", "active", "paused", "rejected", "completed"] },
        "type": { "type": "string", "enum": ["cpc", "cpm"] },
        "budget": { "type": "number" },
        "spent": { "type": "number" },
        "results": { "type": "number" }
      },
      "required": ["id", "userId", "campaignName", "status", "type"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "Stores user profiles." }
      },
      {
        "path": "/users/{userId}/followers/{followerId}",
        "definition": { "entityName": "Follower", "description": "List of users following this user." }
      },
      {
        "path": "/users/{userId}/following/{followedId}",
        "definition": { "entityName": "Following", "description": "List of users this user follows." }
      }
    ]
  }
}
