
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Starryz5 platform, whether registered or anonymous.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "usernameLower": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "profilePhotoUrl": { "type": "string" },
        "country": { "type": "string" },
        "gender": { "type": "string" },
        "description": { "type": "string", "maxLength": 160 },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "referralCount": { "type": "number" },
        "viewCount": { "type": "number" },
        "visitCount": { "type": "number" },
        "lastVisit": { "type": "string", "format": "date-time" }
      },
      "required": ["id"]
    },
    "PublicFigure": {
      "title": "PublicFigure",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "viewCount": { "type": "number" }
      }
    },
    "NewsItem": {
      "title": "NewsItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "figureId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "url": { "type": "string", "format": "uri" },
        "domain": { "type": "string" },
        "publisher": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "GalleryItem": {
      "title": "GalleryItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "imageUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Comment": {
      "title": "Comment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "viewCount": { "type": "number" }
      }
    },
    "Thought": {
      "title": "Thought",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "viewCount": { "type": "number" }
      }
    },
    "Follower": {
      "title": "Follower",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "profilePhotoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Following": {
      "title": "Following",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "profilePhotoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AdCampaign": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdCampaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "campaignName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "pending_review", "active", "paused", "rejected", "completed"] },
        "type": { "type": "string", "enum": ["cpc", "cpm"] },
        "budget": { "type": "number" },
        "spent": { "type": "number" },
        "results": { "type": "number" }
      },
      "required": ["id", "userId", "campaignName", "status", "type"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "User", "description": "Stores user profiles." }
      },
      {
        "path": "/figures/{figureId}",
        "definition": { "entityName": "PublicFigure", "description": "Stores character profiles." }
      },
      {
        "path": "/figures/{figureId}/news/{newsId}",
        "definition": { "entityName": "NewsItem", "description": "Stores news related to a public figure." }
      },
      {
        "path": "/figures/{figureId}/gallery/{photoId}",
        "definition": { "entityName": "GalleryItem", "description": "Stores gallery photos for a public figure." }
      },
      {
        "path": "/figures/{figureId}/comments/{commentId}",
        "definition": { "entityName": "Comment", "description": "Stores StarPosts/Reviews." }
      },
      {
        "path": "/figures/{figureId}/thoughts/{thoughtId}",
        "definition": { "entityName": "Thought", "description": "Stores Thoughts/Posts." }
      },
      {
        "path": "/users/{userId}/followers/{followerId}",
        "definition": { "entityName": "Follower", "description": "List of users following this user." }
      },
      {
        "path": "/users/{userId}/following/{followedId}",
        "definition": { "entityName": "Following", "description": "List of users this user follows." }
      }
    ]
  }
}
